rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Validation Blueprint
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'adsWatched', 'updatedAt', 'telegramId', 'balance'])
        && data.username is string && data.username.size() <= 100
        && data.adsWatched is number && data.adsWatched >= 0
        && data.balance is number && data.balance >= 0
        && data.updatedAt == request.time
        && data.telegramId is number;
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['amount', 'method', 'status', 'createdAt', 'userId'])
        && data.amount is number && data.amount >= 1667
        && data.method is string
        && (data.status == 'Pending' || data.status == 'Success' || data.status == 'Rejected')
        && data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isSignedIn(); 
      allow list: if isSignedIn(); 
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidId(userId) && (
        // Action: Owner self-update
        incoming().updatedAt == request.time &&
        incoming().telegramId == existing().telegramId
      ) || (
        // Action: Referral Reward (50 points from another user)
        isSignedIn() && !isOwner(userId)
        && incoming().balance == existing().balance + 50
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'referralsCount', 'total_invites', 'referralEarnings', 'updatedAt'])
      );

      match /referrals/{refId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn() && isValidId(refId);
      }

      match /withdrawals/{withdrawalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(withdrawalId) && isValidWithdrawal(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidWithdrawal(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      }
    }
  }
}
